{
  "name": "auditjs",
  "version": "4.2.0",
  "description": "Audit dependencies to identify known vulnerabilities and maintenance problems",
  "main": "./bin/index.js",
  "bin": {
    "auditjs": "./bin/index.js"
  },
  "files": [
    "bin/**/*"
  ],
  "preferGlobal": true,
  "engines": {
    "node": ">=16.13.0"
  },
  "resolutions": {
    "braces": "3.0.3",
    "brace-expansion": "^2.0.2",
    "hosted-git-info": "^3.0.8",
    "y18n": "^5.0.8",
    "minimatch": ">=3.0.5",
    "semver": "^7.5.2",
    "read-package-json": ">=7.0.0",
    "glob": ">=12.0.0",
    "cross-spawn": ">=7.0.5"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "build-dev": "tsc -p tsconfig.development.json",
    "coverage": "vitest run --coverage",
    "test-ci": "vitest run --reporter=junit --outputFile=reports/test-results.xml",
    "lint": "eslint src/**/*.ts",
    "start": "node ./bin/index.js",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test",
    "iq-scan": "npx auditjs@latest iq -a auditjs"
  },
  "keywords": [
    "Audit",
    "Scan",
    "Vulnerability",
    "CPE",
    "CVE",
    "CWE",
    "OSSIndex",
    "Artie",
    "Nexus",
    "Sonatype",
    "SCA",
    "SBOM",
    "Security",
    "Advisories"
  ],
  "author": "Sonatype Community",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sonatype-nexus-community/auditjs.git"
  },
  "devDependencies": {
    "@types/figlet": "^1.2.0",
    "@types/js-yaml": "^3.12.2",
    "@types/mock-fs": "^4.10.0",
    "@types/node": "^18.0.0",
    "@types/node-fetch": "^2.5.4",
    "@types/node-persist": "^3.0.0",
    "@types/ssri": "^7.1.5",
    "@types/uuid": "^9.0.7",
    "@types/yargs": "^13.0.8",
    "@types/yarnpkg__lockfile": "^1.1.3",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@yarnpkg/lockfile": "^1.1.0",
    "eslint": "^7.1.0",
    "eslint-config-prettier": "^6.10.0",
    "eslint-plugin-prettier": "^3.1.2",
    "mock-fs": "^5.2.0",
    "msw": "^2.14.6",
    "prettier": "^1.19.1",
    "rimraf": "^4.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.5",
    "chalk": "^3.0.0",
    "colors": "1.4.0",
    "figlet": "^1.2.4",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "3.14.2",
    "log4js": "^6.4.0",
    "node-fetch": "^2.6.8",
    "node-persist": "^3.1.0",
    "ora": "^4.0.3",
    "read-installed": "~4.0.3",
    "spdx-license-ids": "^3.0.5",
    "ssri": "^10.0.6",
    "uuid": "^9.0.1",
    "xmlbuilder": "^13.0.2",
    "yargs": "^16.1.0"
  }
}
